{
  "name": "ts-lsp-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing TypeScript LSP-like functionality to AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ts-lsp-mcp": "dist/bin/ts-lsp-mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
